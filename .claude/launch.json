{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "hattori-landing",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8090", "--directory", "../hattori-landing"],
      "port": 8090
    },
    {
      "name": "hattori-web",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "web", "run", "dev"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
